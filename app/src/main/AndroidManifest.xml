<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FeesManager"
        tools:targetApi="31">

        <!-- Entry: Splash → Language → Role Select -->
        <activity android:name=".SplashActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Chat -->
        <activity android:name=".MessageActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ClassChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ClassSelectChatActivity"
            android:exported="false"/>
        <activity android:name=".StudentQueriesActivity"   android:exported="false" />

        <!-- AI Assistant -->

        <activity android:name=".TeacherAiActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <!-- Advance -->
        <activity android:name=".AdvanceStudentsActivity"  android:exported="false" />
        <activity android:name=".AdvancePaymentActivity"   android:exported="false" />

        <!-- Student join & approval -->
        <activity android:name=".StudentPendingApprovalActivity" android:exported="false" />

        <!-- Language / Settings -->
        <activity android:name=".LanguageSelectActivity"  android:exported="false" />
        <activity android:name=".SettingsActivity"        android:exported="false" />
        <activity android:name=".RazorpayOnboardingActivity" android:exported="false" />
        <!-- Cashfree payment setup screen (NEW — active when AppPaymentConfig.isCashfree) -->
        <activity android:name=".CashfreeOnboardingActivity" android:exported="false" />

        <!-- Auth -->
        <activity android:name=".RoleSelectActivity"      android:exported="false" />
        <activity android:name=".MainActivity"            android:exported="false" />
        <activity android:name=".SetupProfileActivity"    android:exported="false" />

        <!-- Teacher -->
        <activity android:name=".DashboardActivity"       android:exported="false" />
        <activity android:name=".AddStudentActivity"      android:exported="false" />
        <activity android:name=".ViewStudentsActivity"    android:exported="false" />
        <activity android:name=".StudentProfileActivity"  android:exported="false" />
        <activity android:name=".EditStudentActivity"     android:exported="false" />
        <activity android:name=".FeesEntryActivity"       android:exported="false" />
        <activity android:name=".PaymentRequestsActivity" android:exported="false" />
        <activity android:name=".PendingStudentsActivity" android:exported="false" />
        <activity android:name=".SetClassFeesActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ReceiptActivity"         android:exported="false" />
        <activity android:name=".AnalyticsActivity"       android:exported="false" />
        <activity android:name=".AttendanceActivity"      android:exported="false" />
        <activity android:name=".BackupActivity"          android:exported="false" />
        <activity android:name=".AnnouncementsActivity"   android:exported="false" />

        <!-- Student -->
        <activity android:name=".StudentDashboardActivity" android:exported="false" />
        <activity android:name=".StudentLoginActivity"    android:exported="false" />
        <activity android:name=".StudentSignupActivity"   android:exported="false" />
        <activity android:name=".StudentJoinActivity"     android:exported="false" />
        <activity android:name=".StudentFaqActivity"      android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".PayFeesActivity"         android:exported="false" />
        <activity android:name=".HistoryActivity"         android:exported="false" />
        <activity android:name=".FeeCalendarActivity"     android:exported="false" />
        <activity android:name=".MultiAcademyActivity"    android:exported="false" />

        <!-- Razorpay -->
        <activity android:name="com.razorpay.CheckoutActivity"
            android:configChanges="keyboard|keyboardHidden|orientation|uiMode|screenLayout|screenSize|smallestScreenSize"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MaterialComponents.Light.Dialog"
            tools:node="replace" />

        <!-- FCM: Stubbed — NotificationHelper handles logging. Service class removed. -->
    </application>
</manifest>

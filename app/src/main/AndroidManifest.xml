<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_app_premium"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_app_premium"
        android:supportsRtl="true"
        android:theme="@style/Theme.FeesManager"
        tools:targetApi="31">

        <!-- Entry: Splash → Language → Role Select -->
        <activity android:name=".ui.auth.SplashActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Chat -->
        <activity android:name=".ui.chat.MessageActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ui.chat.ClassChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ui.chat.ClassSelectChatActivity"
            android:exported="false"/>
        <activity android:name=".ui.chat.ChatHubActivity"
            android:exported="false"/>
        <activity android:name=".ui.chat.StudentQueriesActivity"   android:exported="false" />

        <!-- AI Assistant -->

        <activity android:name=".ai.ui.TeacherAiActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>

        <!-- Advance -->
        <activity android:name=".ui.advances.AdvanceStudentsActivity"  android:exported="false" />
        <activity android:name=".ui.advances.AdvancePaymentActivity"   android:exported="false" />

        <!-- Student join & approval -->
        <activity android:name=".ui.student.StudentPendingApprovalActivity" android:exported="false" />

        <!-- Language / Settings -->
        <activity android:name=".ui.auth.LanguageSelectActivity"  android:exported="false" />
        <activity android:name=".ui.settings.SettingsActivity"        android:exported="false" />
        <activity android:name=".ui.profile.EditProfileActivity"        android:exported="false" />
        <activity android:name=".ui.profile.StudentEditProfileActivity" android:exported="false" />
        <activity android:name=".ui.student.AboutTeacherActivity" android:exported="false" />
        <!-- Cashfree payment setup screen (NEW — active when AppPaymentConfig.isCashfree) -->
        <activity android:name=".ui.payment.CashfreeOnboardingActivity" android:exported="false" />

        <!-- Auth — Unified Login (replaces MainActivity, StudentLoginActivity, StudentSignupActivity, RoleSelectActivity) -->
        <activity android:name=".ui.auth.LoginActivity"          android:exported="false" />
        <activity android:name=".ui.auth.SetupProfileActivity"   android:exported="false" />

        <!-- Teacher -->
        <activity android:name=".ui.dashboard.DashboardActivity"       android:exported="false" />
        <activity android:name=".ui.student.AddStudentActivity"      android:exported="false" />
        <activity android:name=".ui.student.ViewStudentsActivity"    android:exported="false" />
        <activity android:name=".ui.student.StudentProfileActivity"  android:exported="false" />
        <activity android:name=".ui.student.EditStudentActivity"     android:exported="false" />
        <activity android:name=".ui.fees.FeesEntryActivity"       android:exported="false" />
        <activity android:name=".ui.payment.PaymentRequestsActivity" android:exported="false" />
        <activity android:name=".ui.student.PendingStudentsActivity" android:exported="false" />
        <activity android:name=".ui.fees.SetClassFeesActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ui.fees.ReceiptActivity"         android:exported="false" />
        <activity android:name=".ui.analytics.AnalyticsActivity"       android:exported="false" />
        <activity android:name=".ui.attendance.AttendanceActivity"      android:exported="false" />
        <activity android:name=".ui.settings.BackupActivity"          android:exported="false" />
        <activity android:name=".ui.announcements.AnnouncementsActivity"   android:exported="false" />

        <!-- Student -->
        <activity android:name=".ui.dashboard.StudentDashboardActivity" android:exported="false" />
        <activity android:name=".ui.student.StudentJoinActivity"     android:exported="false" />
        <activity android:name=".ui.settings.StudentFaqActivity"      android:exported="false"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ui.fees.PayFeesActivity"         android:exported="false" />
        <activity android:name=".ui.fees.HistoryActivity"         android:exported="false" />
        <activity android:name=".ui.fees.FeeCalendarActivity"     android:exported="false" />
        <activity android:name=".ui.settings.MultiAcademyActivity"    android:exported="false" />

        <!-- FCM: Stubbed — NotificationHelper handles logging. Service class removed. -->

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>

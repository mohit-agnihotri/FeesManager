<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Animated Entrance Wrapper -->
        <LinearLayout android:id="@+id/contentWrapper" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- This Month Fees Summary -->
            <TextView android:text="@string/this_month" android:textColor="@color/text_muted" android:textSize="13sp" android:letterSpacing="0.1" android:textStyle="bold" android:layout_marginBottom="12dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <LinearLayout android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <ImageView android:src="@drawable/ic_payment" app:tint="@color/yellow" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginEnd="16dp"/>
                        <TextView android:text="@string/total_fees" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvTotalFees" android:text="₹0" android:textColor="@color/text_primary" android:textSize="22sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    
                    <LinearLayout android:orientation="horizontal" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/bg_header">
                        <com.google.android.material.card.MaterialCardView
                            android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp" app:cardBackgroundColor="@color/green" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                            <LinearLayout android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                                <TextView android:text="@string/paid" android:textColor="#A7F3D0" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:id="@+id/tvPaid" android:text="₹0" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_marginStart="6dp" app:cardBackgroundColor="@color/red" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                            <LinearLayout android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                                <TextView android:text="@string/pending" android:textColor="#FECACA" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                                <TextView android:id="@+id/tvPending" android:text="₹0" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Advance Balance Card -->
            <com.google.android.material.card.MaterialCardView android:id="@+id/cardAdvanceBalance"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_advance" app:tint="@color/indigo_light" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="12dp"/>
                    <TextView android:text="@string/advance_balance" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvAdvanceBalance" android:text="₹0" android:textColor="@color/indigo_light" android:textSize="18sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pay Fees Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPay"
                android:text="@string/pay_fees_now"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/indigo"/>

            <!-- Quick Actions Section -->
            <TextView android:text="QUICK ACTIONS" android:textColor="@color/text_muted" android:textSize="13sp" android:letterSpacing="0.1" android:textStyle="bold" android:layout_marginBottom="12dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            
            <LinearLayout android:orientation="horizontal" android:layout_marginBottom="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <com.google.android.material.card.MaterialCardView android:id="@+id/btnHistory" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <ImageView android:src="@drawable/ic_history" app:tint="@color/cyan" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                        <TextView android:text="@string/history" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView android:id="@+id/btnCalendar" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <ImageView android:src="@drawable/ic_calendar" app:tint="@color/cyan" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                        <TextView android:text="@string/calendar" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Communication Section -->
            <TextView android:text="COMMUNICATION" android:textColor="@color/text_muted" android:textSize="13sp" android:letterSpacing="0.1" android:textStyle="bold" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            
            <LinearLayout android:orientation="horizontal" android:layout_marginBottom="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <com.google.android.material.card.MaterialCardView android:id="@+id/btnContactTeacher" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                            <ImageView android:src="@drawable/ic_chat" app:tint="@color/orange" android:layout_width="32dp" android:layout_height="32dp"/>
                            <!-- Assuming you might want a badge here, you can add it via code later -->
                        </FrameLayout>
                        <TextView android:text="@string/contact_teacher" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView android:id="@+id/btnClassChat" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                    <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <FrameLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                            <ImageView android:src="@drawable/ic_groups" app:tint="@color/orange" android:layout_width="32dp" android:layout_height="32dp"/>
                        </FrameLayout>
                        <TextView android:text="@string/class_chat" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView android:id="@+id/btnMyAcademies" android:layout_marginBottom="40dp" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_academy" app:tint="@color/text_secondary" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginEnd="16dp"/>
                    <TextView android:text="@string/my_academies" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <ImageView android:src="@drawable/ic_arrow_right" app:tint="@color/text_muted" android:layout_width="20dp" android:layout_height="20dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

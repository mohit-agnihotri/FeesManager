<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E" android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <LinearLayout android:orientation="horizontal" android:background="@drawable/bg_header_dark"
        android:padding="16dp" android:gravity="center_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="👥 All Students" android:textSize="20sp"
            android:textStyle="bold" android:textColor="#F1F5F9" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvStudentCount" android:text="0 students"
            android:textColor="#6366F1" android:textSize="13sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Search — FIXED: etSearch → searchBox -->
    <EditText android:id="@+id/searchBox" android:hint="🔍 Search students..."
        android:textColor="#F1F5F9" android:textColorHint="#475569"
        android:background="@drawable/bg_input_field" android:padding="14dp"
        android:layout_margin="12dp" android:layout_width="match_parent" android:layout_height="48dp"/>

    <!-- Filter buttons — ADDED (were missing entirely) -->
    <LinearLayout android:orientation="horizontal"
        android:paddingLeft="12dp" android:paddingRight="12dp" android:paddingBottom="8dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <Button android:id="@+id/btnAll" android:text="All"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="13sp"
            android:backgroundTint="#6366F1" android:stateListAnimator="@null"
            android:layout_weight="1" android:layout_marginEnd="4dp"
            android:layout_width="0dp" android:layout_height="40dp"/>
        <Button android:id="@+id/btnClass" android:text="By Class"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="13sp"
            android:backgroundTint="#0891B2" android:stateListAnimator="@null"
            android:layout_weight="1" android:layout_marginEnd="4dp"
            android:layout_width="0dp" android:layout_height="40dp"/>
        <Button android:id="@+id/btnPending" android:text="Pending"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="13sp"
            android:backgroundTint="#EF4444" android:stateListAnimator="@null"
            android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="40dp"/>
    </LinearLayout>

    <!-- List — FIXED: studentList → listViewStudents -->
    <ScrollView android:id="@+id/studentScroll" android:layout_weight="1" android:layout_width="match_parent" android:layout_height="0dp">
        <LinearLayout android:id="@+id/listViewStudents" android:orientation="vertical"
            android:paddingLeft="16dp" android:paddingRight="16dp" android:paddingBottom="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </ScrollView>
</LinearLayout>

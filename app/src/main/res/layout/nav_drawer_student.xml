<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0F172A" android:orientation="vertical"
    android:layout_width="280dp" android:layout_height="match_parent">

    <!-- Header -->
    <LinearLayout android:orientation="vertical"
        android:background="@drawable/bg_header_dark"
        android:paddingLeft="20dp" android:paddingRight="20dp"
        android:paddingTop="40dp" android:paddingBottom="24dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivDrawerProfile"
            android:src="@drawable/ic_person_placeholder"
            android:layout_marginBottom="8dp"
            android:layout_width="60dp" android:layout_height="60dp"/>
        <TextView android:id="@+id/drawerStudentName" android:text="Student"
            android:textSize="18sp" android:textStyle="bold" android:textColor="#F1F5F9"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/drawerStudentClass" android:text="Class --"
            android:textSize="13sp" android:textColor="#94A3B8"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/drawerAcademyName" android:text="Academy Name"
            android:textSize="12sp" android:textColor="#6366F1" android:textStyle="italic"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <ScrollView android:layout_weight="1"
        android:layout_width="match_parent" android:layout_height="0dp">
        <LinearLayout android:orientation="vertical" android:padding="12dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <include layout="@layout/nav_item" android:id="@+id/navProfile"/>

            <TextView android:text="MY ACADEMIES" android:textColor="#475569"
                android:textSize="10sp" android:letterSpacing="0.15"
                android:paddingLeft="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <include layout="@layout/nav_item" android:id="@+id/navAcademies"/>

            <TextView android:text="PAYMENTS" android:textColor="#475569"
                android:textSize="10sp" android:letterSpacing="0.15"
                android:paddingLeft="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <include layout="@layout/nav_item" android:id="@+id/navPayHistory"/>
            <include layout="@layout/nav_item" android:id="@+id/navPendingFees"/>
            <include layout="@layout/nav_item" android:id="@+id/navAdvanceBalance"/>

            <TextView android:text="MORE" android:textColor="#475569"
                android:textSize="10sp" android:letterSpacing="0.15"
                android:paddingLeft="16dp" android:paddingTop="12dp" android:paddingBottom="4dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <include layout="@layout/nav_item" android:id="@+id/navNotifications"/>

            <include layout="@layout/nav_item" android:id="@+id/navSettings"/>
            <include layout="@layout/nav_item" android:id="@+id/navAbout"/>
        </LinearLayout>
    </ScrollView>

    <!-- Logout -->

        <include layout="@layout/nav_item" android:id="@+id/navLanguage"/>
    <LinearLayout android:id="@+id/navLogout" android:orientation="horizontal"
        android:background="@drawable/ripple_card" android:padding="16dp"
        android:gravity="center_vertical" android:clickable="true" android:focusable="true"
        android:layout_margin="12dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="🚪" android:textSize="20sp" android:layout_marginEnd="14dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:text="@string/nav_logout" android:textColor="#EF4444"
            android:textSize="15sp" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>

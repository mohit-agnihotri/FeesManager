<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_gradient_main"
    android:fillViewport="true"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <LinearLayout android:orientation="vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <!-- Hero -->
        <LinearLayout android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_header_dark"
            android:paddingTop="56dp" android:paddingBottom="40dp"
            android:paddingLeft="32dp" android:paddingRight="32dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <TextView android:text="🎓" android:textSize="52sp" android:gravity="center"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

            <TextView android:text="Welcome Back"
                android:textSize="24sp" android:textStyle="bold" android:textColor="#F1F5F9"
                android:gravity="center" android:layout_marginBottom="4dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

            <TextView android:text="Student Login"
                android:textSize="14sp" android:textColor="#34D399" android:gravity="center"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="vertical"
            android:paddingLeft="20dp" android:paddingRight="20dp"
            android:paddingTop="28dp" android:paddingBottom="32dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <TextView android:text="Email Address" android:textColor="#94A3B8"
                android:textSize="13sp" android:layout_marginBottom="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etEmail" android:hint="your@email.com"
                android:textColor="#F1F5F9" android:textColorHint="#475569"
                android:background="@drawable/bg_input_modern" android:padding="16dp"
                android:inputType="textEmailAddress" android:textSize="15sp"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <TextView android:text="Password" android:textColor="#94A3B8"
                android:textSize="13sp" android:layout_marginBottom="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etPassword" android:hint="Min 6 characters"
                android:textColor="#F1F5F9" android:textColorHint="#475569"
                android:background="@drawable/bg_input_modern" android:padding="16dp"
                android:inputType="textPassword" android:textSize="15sp"
                android:layout_marginBottom="28dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <Button android:id="@+id/btnLogin" android:text="Login"
                android:textColor="#fff" android:textSize="16sp" android:textStyle="bold"
                android:textAllCaps="false" android:backgroundTint="#22C55E"
                android:stateListAnimator="@null" android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <View android:background="#2D3F55" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="1dp"/>
                <TextView android:text="  or continue with  " android:textColor="#475569"
                    android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <View android:background="#2D3F55" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="1dp"/>
            </LinearLayout>

            <Button android:id="@+id/btnGoogleLogin"
                android:text="  Sign in with Google" android:textAllCaps="false"
                android:textColor="#0F172A" android:textSize="15sp"
                android:background="@drawable/bg_btn_white"
                android:stateListAnimator="@null" android:layout_marginBottom="28dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <TextView android:id="@+id/tvSignup"
                android:text="Don't have an account? Sign Up →"
                android:textColor="#34D399" android:textSize="14sp"
                android:gravity="center" android:padding="8dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>

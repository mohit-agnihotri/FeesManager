<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_primary">

    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="@dimen/screen_padding"
        android:paddingRight="@dimen/screen_padding"
        android:paddingTop="@dimen/screen_padding"
        android:paddingBottom="80dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Stats Row -->
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView
                android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginEnd="6dp" app:cardBackgroundColor="@color/indigo" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="@string/students" android:textColor="#C7D2FE" android:textSize="@dimen/text_xs" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvTotalStudents" android:text="0" android:textColor="@color/white" android:textSize="28sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginStart="3dp" android:layout_marginEnd="3dp" app:cardBackgroundColor="@color/green" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="@string/collected" android:textColor="#A7F3D0" android:textSize="@dimen/text_xs" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvCollected" android:text="₹0" android:textColor="@color/white" android:textSize="22sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/pendingCardBtn"
                android:clickable="true" android:focusable="true"
                android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginStart="6dp" app:cardBackgroundColor="@color/red" app:cardCornerRadius="16dp" app:cardElevation="0dp">
                <LinearLayout android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="@string/pending" android:textColor="#FECACA" android:textSize="@dimen/text_xs" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvPending" android:text="₹0" android:textColor="@color/white" android:textSize="17sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Total Fees -->
        <com.google.android.material.card.MaterialCardView
            android:layout_marginBottom="24dp" android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp">
            <LinearLayout android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <ImageView android:src="@drawable/ic_payment" app:tint="@color/yellow" android:layout_width="28dp" android:layout_height="28dp" android:layout_marginEnd="16dp"/>
                <TextView android:text="@string/total_fees" android:textColor="@color/text_secondary" android:textSize="@dimen/text_sm" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvTotalFees" android:text="₹0" android:textColor="@color/text_primary" android:textSize="22sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Students Section -->
        <TextView android:text="@string/students" android:textColor="@color/text_muted" android:textSize="13sp" android:letterSpacing="0.1" android:textStyle="bold" android:layout_marginBottom="12dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView android:id="@+id/addStudentBtn" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_add_student" app:tint="@color/indigo_light" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/add_student" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/viewStudentBtn" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_students" app:tint="@color/indigo_light" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/view_all" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Fees Section -->
        <TextView android:text="@string/fees" android:textColor="@color/text_muted" android:textSize="13sp" android:letterSpacing="0.1" android:textStyle="bold" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView android:id="@+id/feesBtn" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_payment" app:tint="@color/green_light" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/record_payment" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/btnSetFees" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_settings" app:tint="@color/green_light" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/set_class_fees" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btnAnalytics" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_analytics" app:tint="@color/orange" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/analytics" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/btnAdvanceStudents" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_advance" app:tint="@color/orange" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/advances" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Tools Section -->
        <TextView android:text="@string/tools" android:textColor="@color/text_muted" android:textSize="13sp" android:letterSpacing="0.1" android:textStyle="bold" android:layout_marginTop="12dp" android:layout_marginBottom="12dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btnAttendance" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_attendance" app:tint="@color/cyan" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/attendance" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/btnAnnouncements" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_announcement" app:tint="@color/cyan" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/announcements" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:layout_marginBottom="12dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btnBackup" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="16dp" app:cardElevation="0dp" android:clickable="true" android:focusable="true">
                <LinearLayout android:orientation="vertical" android:gravity="center" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:src="@drawable/ic_backup" app:tint="@color/text_secondary" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginBottom="8dp"/>
                    <TextView android:text="@string/export_data" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <View android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="1dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>

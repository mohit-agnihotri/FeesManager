<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E" android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <!-- Header -->
    <LinearLayout android:orientation="horizontal"
        android:background="@drawable/bg_header_dark"
        android:paddingLeft="20dp" android:paddingRight="20dp"
        android:paddingTop="20dp" android:paddingBottom="20dp"
        android:gravity="center_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="⚙️" android:textSize="22sp" android:layout_marginEnd="12dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:text="@string/settings" android:textSize="20sp"
            android:textStyle="bold" android:textColor="#F1F5F9"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:padding="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- Language -->
            <TextView android:text="🌍  LANGUAGE" android:textColor="#475569"
                android:textSize="11sp" android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" android:layout_marginTop="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <LinearLayout android:id="@+id/rowLanguage" android:orientation="horizontal"
                android:background="@drawable/ripple_card" android:padding="18dp"
                android:gravity="center_vertical" android:clickable="true" android:focusable="true"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="Language / भाषा" android:textColor="#F1F5F9"
                    android:textSize="15sp" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvCurrentLang" android:text="English"
                    android:textColor="#818CF8" android:textSize="13sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Appearance -->
            <TextView android:text="🎨  APPEARANCE" android:textColor="#475569"
                android:textSize="11sp" android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <LinearLayout android:orientation="horizontal"
                android:background="@drawable/bg_card_modern" android:padding="18dp"
                android:gravity="center_vertical" android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/dark_mode" android:textColor="#F1F5F9"
                    android:textSize="15sp" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"/>
                <Switch android:id="@+id/switchDarkMode" android:checked="true"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Notifications -->
            <TextView android:text="🔔  NOTIFICATIONS" android:textColor="#475569"
                android:textSize="11sp" android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <LinearLayout android:orientation="vertical"
                android:background="@drawable/bg_card_modern" android:padding="18dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="@string/enable_notifications" android:textColor="#F1F5F9"
                        android:textSize="15sp" android:layout_weight="1"
                        android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <Switch android:id="@+id/switchNotifications" android:checked="true"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="@string/notification_sound" android:textColor="#F1F5F9"
                        android:textSize="15sp" android:layout_weight="1"
                        android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <Switch android:id="@+id/switchSound" android:checked="true"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Security -->
            <TextView android:text="🔐  SECURITY" android:textColor="#475569"
                android:textSize="11sp" android:letterSpacing="0.15"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <LinearLayout android:id="@+id/rowChangePassword"
                android:orientation="horizontal" android:background="@drawable/ripple_card"
                android:padding="18dp" android:gravity="center_vertical"
                android:clickable="true" android:focusable="true" android:layout_marginBottom="8dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="🔑  Change Password" android:textColor="#F1F5F9"
                    android:textSize="15sp" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:text="›" android:textColor="#475569" android:textSize="22sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/rowLogoutAll"
                android:orientation="horizontal" android:background="@drawable/ripple_card"
                android:padding="18dp" android:gravity="center_vertical"
                android:clickable="true" android:focusable="true" android:layout_marginBottom="32dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="🚪  Logout from all devices"
                    android:textColor="#EF4444" android:textSize="15sp" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"/>
                <TextView android:text="›" android:textColor="#475569" android:textSize="22sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>

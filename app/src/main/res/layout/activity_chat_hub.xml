<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💬 Chat"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#F1F5F9"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select a chat type to continue"
            android:textSize="13sp"
            android:textColor="#94A3B8"
            android:layout_marginBottom="32dp" />

        <!-- Personal Chat Card -->
        <FrameLayout
            android:id="@+id/cardPersonalChat"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_modern"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Personal Chat"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1-on-1 messages with individual students"
                    android:textSize="13sp"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Unread badge -->
            <TextView
                android:id="@+id/tvPersonalBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:minWidth="24dp"
                android:minHeight="24dp"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_red"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Class Chat Card -->
        <FrameLayout
            android:id="@+id/cardClassChat"
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card_modern"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚 Class Chat"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#F1F5F9" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Group chats for each class"
                    android:textSize="13sp"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Unread badge -->
            <TextView
                android:id="@+id/tvClassBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:minWidth="24dp"
                android:minHeight="24dp"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_red"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>
</ScrollView>

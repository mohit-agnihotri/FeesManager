<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal" android:background="@drawable/ripple_card"
    android:padding="16dp" android:gravity="center_vertical"
    android:clickable="true" android:focusable="true"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="2dp">

    <TextView android:id="@+id/navItemIcon" android:text="📌" android:textSize="20sp"
        android:layout_marginEnd="14dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/navItemLabel" android:text="Item"
        android:textColor="#CBD5E1" android:textSize="15sp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>

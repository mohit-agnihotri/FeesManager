<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0B1120"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header with avatar, name, status -->
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/bg_header_dark"
        android:paddingLeft="12dp" android:paddingRight="16dp"
        android:paddingTop="12dp" android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:elevation="4dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <TextView android:id="@+id/btnBack"
            android:text="←" android:textSize="24sp" android:textColor="#F1F5F9"
            android:paddingEnd="12dp" android:paddingStart="4dp"
            android:clickable="true" android:focusable="true"
            android:background="@drawable/ripple_card"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <!-- Avatar circle -->
        <FrameLayout android:layout_marginEnd="12dp"
            android:layout_width="44dp" android:layout_height="44dp">
            <ImageView android:id="@+id/ivChatAvatar"
                android:src="@drawable/ic_person_placeholder"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle"
                android:layout_width="44dp" android:layout_height="44dp"/>
            <TextView android:id="@+id/tvAvatarInitial"
                android:text="?" android:textSize="18sp" android:textStyle="bold"
                android:textColor="#fff" android:gravity="center"
                android:background="@drawable/bg_avatar_circle"
                android:layout_width="44dp" android:layout_height="44dp"/>
        </FrameLayout>

        <!-- Name + status -->
        <LinearLayout android:orientation="vertical" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="wrap_content">
            <TextView android:id="@+id/tvMessageTitle"
                android:text="Chat" android:textSize="16sp"
                android:textStyle="bold" android:textColor="#F1F5F9"
                android:maxLines="1"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvOnlineStatus"
                android:text="online" android:textSize="11sp" android:textColor="#22C55E"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Messages scrollable area -->
    <ScrollView android:id="@+id/messageScroll"
        android:layout_weight="1" android:fillViewport="false"
        android:scrollbarStyle="insideOverlay"
        android:layout_width="match_parent" android:layout_height="0dp">
        <LinearLayout android:id="@+id/messageContainer"
            android:orientation="vertical"
            android:paddingTop="12dp" android:paddingBottom="12dp"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </ScrollView>

    <!-- Typing indicator -->
    <TextView android:id="@+id/tvTypingIndicator"
        android:text="" android:textSize="12sp" android:textColor="#6366F1"
        android:paddingLeft="16dp" android:paddingBottom="2dp"
        android:visibility="gone"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <!-- Input row -->
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/bg_header_dark"
        android:paddingLeft="8dp" android:paddingRight="8dp"
        android:paddingTop="8dp" android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <EditText android:id="@+id/etMessageInput"
            android:hint="Type a message…"
            android:textColor="#F1F5F9" android:textColorHint="#4B5563"
            android:background="@drawable/bg_input_chat"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingTop="12dp" android:paddingBottom="12dp"
            android:textSize="15sp" android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4" android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:layout_width="0dp" android:layout_height="wrap_content"/>

        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_width="wrap_content" android:layout_height="wrap_content">

            <ImageView android:id="@+id/btnAttach"
                android:src="@android:drawable/ic_menu_agenda"
                android:tint="#94A3B8"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="4dp"
                android:layout_width="40dp" android:layout_height="40dp"/>

            <Button android:id="@+id/btnSendMessage"
                android:text="➤" android:textAllCaps="false"
                android:textColor="#fff" android:textSize="20sp"
                android:background="@drawable/bg_send_btn"
                android:stateListAnimator="@null"
                android:elevation="2dp"
                android:layout_width="52dp" android:layout_height="52dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

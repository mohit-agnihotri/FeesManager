<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E" android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="horizontal" android:background="@drawable/bg_header_dark"
        android:padding="16dp" android:gravity="center_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="🧾 Receipt" android:textSize="20sp" android:textStyle="bold"
            android:textColor="#F1F5F9" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
    <ScrollView android:layout_weight="1" android:layout_width="match_parent" android:layout_height="0dp">
        <LinearLayout android:orientation="vertical" android:padding="20dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:background="@drawable/bg_card" android:orientation="vertical"
                android:padding="24dp" android:layout_marginBottom="20dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvAcademyName" android:text="Academy"
                    android:textSize="18sp" android:textStyle="bold" android:textColor="#F1F5F9"
                    android:layout_marginBottom="2dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvTeacherName" android:text="By Teacher"
                    android:textColor="#94A3B8" android:textSize="13sp" android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <View android:background="#2D3F55" android:layout_marginBottom="16dp"
                    android:layout_width="match_parent" android:layout_height="1dp"/>
                <TextView android:text="PAYMENT RECEIPT" android:textColor="#6366F1"
                    android:textSize="12sp" android:letterSpacing="0.1" android:gravity="center"
                    android:layout_marginBottom="16dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvStudentName" android:text="Student: --"
                    android:textColor="#F1F5F9" android:textSize="16sp" android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="💰 Paid Now" android:textColor="#94A3B8" android:textSize="14sp"
                        android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvAmountPaid" android:text="₹0" android:textColor="#22C55E"
                        android:textSize="16sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="📊 Total Paid" android:textColor="#94A3B8" android:textSize="14sp"
                        android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvTotalPaid" android:text="₹0" android:textColor="#F1F5F9"
                        android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="⏳ Remaining" android:textColor="#94A3B8" android:textSize="14sp"
                        android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvRemaining" android:text="₹0" android:textColor="#EF4444"
                        android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="💳 Mode" android:textColor="#94A3B8" android:textSize="14sp"
                        android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvMode" android:text="--" android:textColor="#F1F5F9"
                        android:textSize="14sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:orientation="horizontal" android:layout_marginBottom="16dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="🔑 Txn ID" android:textColor="#94A3B8" android:textSize="14sp"
                        android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvTxnId" android:text="--" android:textColor="#6366F1"
                        android:textSize="12sp" android:fontFamily="monospace" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <View android:background="#2D3F55" android:layout_marginBottom="16dp"
                    android:layout_width="match_parent" android:layout_height="1dp"/>
                <TextView android:id="@+id/tvDateTime" android:text="Date &amp; Time"
                    android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Thank you 🙏\nFees Manager Pro"
                    android:textColor="#94A3B8" android:textSize="13sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout android:orientation="vertical" android:padding="16dp"
        android:background="#0A0F1E" android:layout_width="match_parent" android:layout_height="wrap_content">
        
    <TextView android:id="@+id/tvReceiptAdvance"
        android:text="💜 Advance stored"
        android:textSize="14sp" android:textColor="#A78BFA"
        android:gravity="center" android:visibility="gone"
        android:background="#1A1A3E" android:padding="10dp"
        android:layout_margin="16dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
<Button android:id="@+id/btnSaveReceipt" android:text="💾 Save Receipt"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="15sp"
            android:backgroundTint="#6366F1" android:stateListAnimator="@null"
            android:layout_marginBottom="8dp" android:layout_width="match_parent" android:layout_height="52dp"/>
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@+id/btnShareReceipt" android:text="📤 Share"
                android:textAllCaps="false" android:textColor="#F1F5F9" android:textSize="14sp"
                android:background="@drawable/bg_card" android:backgroundTint="@null"
                android:stateListAnimator="@null" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="48dp"/>
            <Button android:id="@+id/btnWhatsApp" android:text="💬 WhatsApp"
                android:textAllCaps="false" android:textColor="#fff" android:textSize="14sp"
                android:backgroundTint="#25D366" android:stateListAnimator="@null"
                android:layout_weight="1" android:layout_marginStart="6dp"
                android:layout_width="0dp" android:layout_height="48dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Toolbar -->
    <LinearLayout android:orientation="horizontal" android:background="@drawable/bg_header_dark" android:padding="16dp" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="💳 Pay Fees" android:textSize="20sp" android:textStyle="bold" android:textColor="#F1F5F9" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:padding="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- Student Info Card -->
            <LinearLayout android:background="@drawable/bg_card" android:orientation="vertical" android:padding="20dp" android:layout_marginBottom="20dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvStudentInfo" android:text="Loading..." android:textColor="#F1F5F9" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvPendingAmount" android:text="Total Pending: ₹0" android:textColor="#EF4444" android:textSize="22sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Amount Input -->
            <TextView android:text="Amount to Pay (₹)" android:textColor="#94A3B8" android:textSize="13sp" android:layout_marginBottom="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etAmount"
                android:hint="Enter amount"
                android:textColor="#F1F5F9"
                android:textColorHint="#475569"
                android:background="@drawable/bg_input_field"
                android:padding="16dp"
                android:inputType="number"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
            android:minHeight="@dimen/tile_min_height"/>

            <ProgressBar android:id="@+id/payProgress" android:visibility="gone" android:layout_gravity="center" android:layout_marginBottom="12dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <!-- Pay Online Button -->
            <Button
                android:id="@+id/btnPayRazorpay"
                android:text="💳  Pay Online (UPI/Card)"
                android:textAllCaps="false"
                android:textColor="#fff"
                android:textSize="17sp"
                android:backgroundTint="#6366F1"
                android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"/>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#2D3F55" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  or  "
                    android:textColor="#475569"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#2D3F55" />
            </LinearLayout>

            <!-- Send Request Button -->
<!--            <Button-->
<!--                android:id="@+id/btnPayRequest"-->
<!--                android:text="📤  Send Request to Teacher"-->
<!--                android:textAllCaps="false"-->
<!--                android:textColor="#94A3B8"-->
<!--                android:textSize="14sp"-->
<!--                android:background="@drawable/bg_card"-->
<!--                android:backgroundTint="@null"-->
<!--                android:stateListAnimator="@null"-->
<!--                android:layout_marginBottom="20dp"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="50dp"/>-->

            <TextView
                android:id="@+id/tvPaymentProviderNote"
                android:text="🔒 Payments secured by Cashfree\nSupports UPI, Cards, Net Banking"
                android:textColor="#475569"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>

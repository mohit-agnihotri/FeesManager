<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg_primary" android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <!-- Search Box -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">
        <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <ImageView android:src="@drawable/ic_search" app:tint="@color/text_muted" android:layout_width="20dp" android:layout_height="20dp"/>
            <EditText android:id="@+id/searchBox" android:hint="Search students..."
                android:textColor="@color/text_primary" android:textColorHint="@color/text_muted"
                android:background="@null" android:padding="14dp" android:textSize="15sp"
                android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Filter chips -->
    <LinearLayout android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="12dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnAll"
            android:text="All" android:textAllCaps="false" android:textSize="13sp"
            app:cornerRadius="16dp" app:backgroundTint="@color/indigo"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:layout_width="0dp" android:layout_height="44dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnClass"
            android:text="By Class" android:textAllCaps="false" android:textSize="13sp"
            app:cornerRadius="16dp" app:backgroundTint="@color/cyan"
            android:layout_weight="1" android:layout_marginEnd="6dp"
            android:layout_width="0dp" android:layout_height="44dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnPending"
            android:text="Pending" android:textAllCaps="false" android:textSize="13sp"
            app:cornerRadius="16dp" app:backgroundTint="@color/red"
            android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="44dp"/>
    </LinearLayout>

    <LinearLayout android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="8dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="DIRECTORY" android:textColor="@color/text_muted" android:textSize="12sp" android:textStyle="bold" android:letterSpacing="0.1" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvStudentCount" android:text="0 students" android:textColor="@color/indigo_light" android:textSize="12sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <ScrollView android:id="@+id/studentScroll" android:layout_weight="1" android:layout_width="match_parent" android:layout_height="0dp">
        <LinearLayout android:id="@+id/listViewStudents" android:orientation="vertical"
            android:paddingLeft="16dp" android:paddingRight="16dp" android:paddingBottom="80dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </ScrollView>
</LinearLayout>

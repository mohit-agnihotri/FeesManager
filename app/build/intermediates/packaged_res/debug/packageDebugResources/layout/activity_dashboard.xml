<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Main Content (FrameLayout to support floating FAB) ── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout android:background="#0A0F1E" android:orientation="vertical"
            android:layout_width="match_parent" android:layout_height="match_parent">

            <!-- Header -->
            <LinearLayout android:orientation="horizontal"
                android:background="@drawable/bg_header_dark"
                android:paddingLeft="@dimen/header_padding_h"
                android:paddingRight="@dimen/header_padding_h"
                android:paddingTop="@dimen/header_padding_v"
                android:paddingBottom="@dimen/header_padding_v"
                android:gravity="center_vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content">

                <!-- Hamburger -->
                <LinearLayout android:id="@+id/btnHamburger" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/ripple_card"
                    android:padding="10dp" android:layout_marginEnd="12dp"
                    android:clickable="true" android:focusable="true"
                    android:layout_width="44dp" android:layout_height="44dp">
                    <TextView android:text="☰" android:textSize="20sp" android:gravity="center"
                        android:textColor="#F1F5F9"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- ✅ NEW: Teacher Avatar — tappable to change photo -->
                <ImageView
                    android:id="@+id/ivTeacherAvatar"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_default_avatar"
                    android:background="@drawable/bg_circle_avatar"
                    android:clickable="true"
                    android:focusable="true"
                    android:scaleType="centerCrop"
                    android:contentDescription="Profile photo"/>

                <!-- Academy name + teacher name + join code -->
                <LinearLayout android:orientation="vertical" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:id="@+id/tvAcademyName" android:text="Academy"
                        android:textSize="@dimen/text_xl" android:textStyle="bold"
                        android:textColor="#F1F5F9" android:maxLines="1" android:ellipsize="end"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvTeacherName" android:text="By Teacher"
                        android:textColor="#94A3B8" android:textSize="@dimen/text_sm"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    <LinearLayout android:orientation="horizontal"
                        android:layout_marginTop="6dp" android:gravity="center_vertical"
                        android:layout_width="wrap_content" android:layout_height="wrap_content">
                        <TextView android:id="@+id/tvJoinCode" android:text="Code: ------"
                            android:textColor="#818CF8" android:textSize="@dimen/text_xs"
                            android:background="@drawable/bg_pill"
                            android:paddingLeft="10dp" android:paddingRight="10dp"
                            android:paddingTop="3dp" android:paddingBottom="3dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/btnRegenJoinCode"
                            android:text="🔄" android:textSize="14sp"
                            android:layout_marginStart="6dp"
                            android:clickable="true" android:focusable="true"
                            android:background="@drawable/ripple_card"
                            android:padding="4dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Theme toggle -->
                <LinearLayout android:id="@+id/btnThemeToggle" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/ripple_card"
                    android:padding="10dp" android:clickable="true" android:focusable="true"
                    android:layout_width="44dp" android:layout_height="44dp">
                    <TextView android:text="🌙" android:textSize="18sp" android:gravity="center"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Scrollable Body -->
            <ScrollView android:layout_weight="1"
                android:layout_width="match_parent" android:layout_height="0dp">
                <LinearLayout android:orientation="vertical"
                    android:paddingLeft="@dimen/screen_padding" android:paddingRight="@dimen/screen_padding"
                    android:paddingTop="@dimen/screen_padding" android:paddingBottom="@dimen/screen_padding"
                    android:layout_width="match_parent" android:layout_height="wrap_content">

                    <!-- Stats Row -->
                    <LinearLayout android:orientation="horizontal" android:layout_marginBottom="10dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:orientation="vertical" android:background="@drawable/bg_card_indigo"
                            android:padding="14dp" android:layout_weight="1" android:layout_marginEnd="5dp"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="@string/students" android:textColor="#A5B4FC"
                                android:textSize="@dimen/text_xs" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvTotalStudents" android:text="0"
                                android:textColor="#E0E7FF" android:textSize="26sp" android:textStyle="bold"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:orientation="vertical" android:background="@drawable/bg_card_green"
                            android:padding="14dp" android:layout_weight="1"
                            android:layout_marginLeft="3dp" android:layout_marginRight="3dp"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="@string/collected" android:textColor="#86EFAC"
                                android:textSize="@dimen/text_xs" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvCollected" android:text="₹0"
                                android:textColor="#DCFCE7" android:textSize="22sp" android:textStyle="bold"
                                android:maxLines="1" android:ellipsize="end"
                                android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:orientation="vertical" android:background="@drawable/bg_card_red"
                            android:padding="14dp" android:layout_weight="1" android:layout_marginStart="5dp"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="@string/pending" android:textColor="#FCA5A5"
                                android:textSize="@dimen/text_xs" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvPending" android:text="₹0"
                                android:textColor="#FEE2E2" android:textSize="17sp" android:textStyle="bold"
                                android:maxLines="2" android:ellipsize="end"
                                android:layout_width="match_parent" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Total Fees -->
                    <LinearLayout android:orientation="horizontal"
                        android:background="@drawable/bg_card_modern"
                        android:padding="16dp" android:gravity="center_vertical"
                        android:layout_marginBottom="16dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:text="💰" android:textSize="20sp" android:layout_marginEnd="10dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="@string/total_fees" android:textColor="#94A3B8"
                            android:textSize="@dimen/text_sm" android:layout_weight="1"
                            android:layout_width="0dp" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvTotalFees" android:text="₹0"
                            android:textColor="#F1F5F9" android:textSize="@dimen/text_lg" android:textStyle="bold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Students Section -->
                    <TextView android:text="@string/students" android:textColor="#475569"
                        android:textSize="@dimen/text_xs" android:letterSpacing="0.15"
                        android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:id="@+id/addStudentBtn" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginEnd="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="➕" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/add_student" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/viewStudentBtn" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginStart="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="👁" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/view_all" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Fees Section -->
                    <TextView android:text="@string/fees" android:textColor="#475569"
                        android:textSize="@dimen/text_xs" android:letterSpacing="0.15"
                        android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:id="@+id/feesBtn" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginEnd="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="💸" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/record_payment" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/btnStudentQueries" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginStart="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="💬" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/class_chat" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:id="@+id/btnSetFees" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginEnd="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="⚙️" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/set_class_fees" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/btnAnalytics" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginStart="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="📊" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/analytics" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:id="@+id/btnAdvanceStudents" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginEnd="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="💳" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/advances" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/btnRazorpayConnect" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginStart="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="💳" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:id="@+id/tvRazorpayStatus" android:text="Connect Pay"
                                android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Tools Section -->
                    <TextView android:text="@string/tools" android:textColor="#475569"
                        android:textSize="@dimen/text_xs" android:letterSpacing="0.15"
                        android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <LinearLayout android:orientation="horizontal" android:layout_marginBottom="8dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:id="@+id/btnAttendance" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginEnd="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="📋" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/attendance" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/btnAnnouncements" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginStart="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="📢" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/announcements" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:orientation="horizontal" android:layout_marginBottom="20dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <LinearLayout android:id="@+id/btnBackup" android:orientation="vertical"
                            android:gravity="center" android:background="@drawable/ripple_card"
                            android:padding="12dp" android:layout_weight="1" android:layout_marginEnd="5dp"
                            android:clickable="true" android:focusable="true"
                            android:minHeight="@dimen/tile_min_height"
                            android:layout_width="0dp" android:layout_height="wrap_content">
                            <TextView android:text="💾" android:textSize="28sp" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="@string/export_data" android:textColor="#94A3B8"
                                android:textSize="@dimen/text_xs" android:gravity="center"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <!-- Empty spacer to keep grid balanced -->
                        <View android:layout_weight="1" android:layout_marginStart="5dp"
                            android:layout_width="0dp" android:layout_height="1dp"/>
                    </LinearLayout>

                    <Button android:id="@+id/btnSwitchAccount"
                        android:text="🔄  Switch Account"
                        android:backgroundTint="#1E293B"
                        android:textColor="#94A3B8"
                        android:layout_marginBottom="16dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <!-- ✅ AI Assistant FAB — floats on top of content -->
        <FrameLayout android:id="@+id/fabAiAssistant"
            android:layout_width="56dp" android:layout_height="56dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp" android:layout_marginBottom="24dp"
            android:background="@drawable/bg_ai_fab"
            android:elevation="8dp"
            android:clickable="true" android:focusable="true">
            <TextView android:text="🤖" android:textSize="24sp"
                android:layout_gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </FrameLayout>

    </FrameLayout>

    <!-- ── Navigation Drawer ──────────────────────────────────── -->
    <include layout="@layout/nav_drawer_teacher" android:id="@+id/navDrawerView"
        android:layout_gravity="start"
        android:layout_width="280dp" android:layout_height="match_parent"/>

</androidx.drawerlayout.widget.DrawerLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <LinearLayout android:padding="20dp" android:orientation="vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <LinearLayout android:orientation="horizontal" android:background="@drawable/bg_header_dark"
            android:padding="16dp" android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="👤 Student Profile" android:textSize="20sp"
                android:textStyle="bold" android:textColor="#F1F5F9"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout android:orientation="vertical" android:background="@drawable/bg_card_modern"
            android:padding="20dp" android:layout_marginBottom="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <TextView android:id="@+id/tvProfileName" android:textColor="#F1F5F9"
                android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvProfileClass" android:textColor="#94A3B8"
                android:textSize="15sp" android:layout_marginBottom="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvProfilePhone" android:textColor="#94A3B8"
                android:textSize="14sp" android:layout_marginBottom="16dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <View android:background="#1E293B" android:layout_marginBottom="12dp"
                android:layout_width="match_parent" android:layout_height="1dp"/>

            <TextView android:id="@+id/tvProfileTotal" android:textColor="#EAB308"
                android:textSize="14sp" android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvProfilePaid" android:textColor="#22C55E"
                android:textSize="15sp" android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvProfileRemain" android:textColor="#EF4444"
                android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="10dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <!-- Advance balance badge -->
            <LinearLayout android:id="@+id/cardProfileAdvance"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_indigo" android:padding="10dp"
                android:visibility="gone"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvProfileAdvance"
                    android:text="💳 Advance: ₹0"
                    android:textColor="#E0E7FF" android:textSize="13sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Buttons -->
        <Button android:id="@+id/btnHistory" android:text="📜 Payment History"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="15sp"
            android:backgroundTint="#0891B2" android:stateListAnimator="@null"
            android:layout_marginBottom="10dp"
            android:layout_width="match_parent" android:layout_height="52dp"/>

        <Button android:id="@+id/btnReceipt" android:text="🧾 Generate Receipt"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="15sp"
            android:backgroundTint="#6366F1" android:stateListAnimator="@null"
            android:layout_marginBottom="10dp"
            android:layout_width="match_parent" android:layout_height="52dp"/>

        <Button android:id="@+id/btnWhatsAppReminder" android:text="📱 Send WhatsApp Reminder"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="15sp"
            android:backgroundTint="#25D366" android:stateListAnimator="@null"
            android:layout_marginBottom="10dp"
            android:layout_width="match_parent" android:layout_height="52dp"/>

        <Button android:id="@+id/btnEditStudent" android:text="✏️ Edit Student"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="15sp"
            android:backgroundTint="#475569" android:stateListAnimator="@null"
            android:layout_width="match_parent" android:layout_height="52dp"/>
        <Button android:id="@+id/btnMessageStudent"
            android:text="💬 Message Student"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="14sp"
            android:background="@drawable/bg_btn_indigo" android:stateListAnimator="@null"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent" android:layout_height="48dp"/>

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.feesmanager"
    android:versionCode="8"
    android:versionName="8.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="36" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission
        android:name="android.permission.NFC"
        android:required="false" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <uses-feature
        android:name="android.hardware.nfc"
        android:required="false" />

    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />

            <data
                android:host="pay"
                android:scheme="upi" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />

            <data
                android:host="mandate"
                android:scheme="upi" />
        </intent>

        <package android:name="com.android.chrome" />

        <intent>
            <action android:name="android.intent.action.VIEW" />

            <data
                android:mimeType="*/*"
                android:scheme="*" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />

            <category android:name="android.intent.category.BROWSABLE" />

            <data
                android:host="pay"
                android:mimeType="*/*"
                android:scheme="upi" />
        </intent>
        <intent>
            <action android:name="android.intent.action.MAIN" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />

            <data android:mimeType="*/*" />
        </intent>
        <intent>
            <action android:name="rzp.device_token.share" />
        </intent>
    </queries>

    <uses-feature
        android:glEsVersion="0x00020000"
        android:required="true" />

    <permission
        android:name="com.example.feesmanager.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.example.feesmanager.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" /> <!-- Normal permission, automatically granted on API 23+ -->
    <uses-permission android:name="android.permission.READ_BASIC_PHONE_STATE" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.FeesManager" >

        <!-- Entry: Splash → Language → Role Select -->
        <activity
            android:name="com.example.feesmanager.SplashActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Chat -->
        <activity
            android:name="com.example.feesmanager.MessageActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name="com.example.feesmanager.ClassChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name="com.example.feesmanager.ClassSelectChatActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.StudentQueriesActivity"
            android:exported="false" />

        <!-- AI Assistant -->

        <activity
            android:name="com.example.feesmanager.TeacherAiActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Advance -->
        <activity
            android:name="com.example.feesmanager.AdvanceStudentsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.AdvancePaymentActivity"
            android:exported="false" />

        <!-- Student join & approval -->
        <activity
            android:name="com.example.feesmanager.StudentPendingApprovalActivity"
            android:exported="false" />

        <!-- Language / Settings -->
        <activity
            android:name="com.example.feesmanager.LanguageSelectActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.SettingsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.RazorpayOnboardingActivity"
            android:exported="false" />
        <!-- Cashfree payment setup screen (NEW — active when AppPaymentConfig.isCashfree) -->
        <activity
            android:name="com.example.feesmanager.CashfreeOnboardingActivity"
            android:exported="false" />

        <!-- Auth -->
        <activity
            android:name="com.example.feesmanager.RoleSelectActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.MainActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.SetupProfileActivity"
            android:exported="false" />

        <!-- Teacher -->
        <activity
            android:name="com.example.feesmanager.DashboardActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.AddStudentActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.ViewStudentsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.StudentProfileActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.EditStudentActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.FeesEntryActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.PaymentRequestsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.PendingStudentsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.SetClassFeesActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name="com.example.feesmanager.ReceiptActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.AnalyticsActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.AttendanceActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.BackupActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.AnnouncementsActivity"
            android:exported="false" />

        <!-- Student -->
        <activity
            android:name="com.example.feesmanager.StudentDashboardActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.StudentLoginActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.StudentSignupActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.StudentJoinActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.StudentFaqActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name="com.example.feesmanager.PayFeesActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.HistoryActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.FeeCalendarActivity"
            android:exported="false" />
        <activity
            android:name="com.example.feesmanager.MultiAcademyActivity"
            android:exported="false" />

        <!-- Razorpay -->
        <activity
            android:name="com.razorpay.CheckoutActivity"
            android:configChanges="keyboard|keyboardHidden|orientation|uiMode|screenLayout|screenSize|smallestScreenSize"
            android:exported="false"
            android:hardwareAccelerated="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MaterialComponents.Light.Dialog" />

        <!-- FCM: Stubbed — NotificationHelper handles logging. Service class removed. -->
        <provider
            android:name="com.cashfree.pg.api.CashfreeCoreContentProvider"
            android:authorities="com.example.feesmanager.cashfreecorecontentprovider"
            android:exported="false" />

        <meta-data
            android:name="cashfree_pg_core_auto_initialization_enabled"
            android:value="@bool/cashfree_pg_core_auto_initialize_enabled" />
        <meta-data
            android:name="cashfree_pg_core_reporting_enabled"
            android:value="@bool/cashfree_pg_core_reporting_enabled" />

        <activity
            android:name="com.cashfree.pg.ui.hidden.checkout.CashfreeNativeCheckoutActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:theme="@style/CFUITheme"
            android:windowSoftInputMode="adjustPan" >
            <intent-filter>
                <action android:name="android.nfc.action.TECH_DISCOVERED" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.TAG_DISCOVERED" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.nfc.action.NDEF_DISCOVERED" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.cashfree.pg.ui.hidden.seamless.CFDropSeamlessActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/CFSeamlessStyle" />

        <meta-data
            android:name="android.webkit.WebView.EnableSafeBrowsing"
            android:value="true" />

        <activity
            android:name="com.cashfree.pg.core.api.ui.CFCoreUPIPaymentActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/CFCoreUPIStyle" />
        <activity
            android:name="com.cashfree.pg.core.api.ui.CFCoreModalActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/CFCoreUPIStyle" />
        <activity
            android:name="com.cashfree.pg.core.api.ui.CashfreeCoreNativeVerificationActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:theme="@style/CFCoreTheme" />
        <activity
            android:name="com.cashfree.pg.core.api.ui.CashfreeSubscriptionCheckoutActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:theme="@style/CFCoreTheme" />
        <activity
            android:name="com.cashfree.pg.core.api.ui.CashfreeWebCheckoutActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/CFWebCheckoutStyle" />

        <meta-data
            android:name="cashfree_pg_logging_level"
            android:value="@integer/cashfree_pg_logging_level" />
        <meta-data
            android:name="cashfree_custom_analytics_subscriber_enabled"
            android:value="@bool/cashfree_custom_analytics_subscriber_enabled" />
        <meta-data
            android:name="cashfree_pg_core_encrypt_pref_enabled"
            android:value="@bool/cashfree_pg_core_encrypt_pref_enabled" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.example.feesmanager.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="com.razorpay.RazorpayInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="com.razorpay.CoreInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="io.github.jan.supabase.storage.SupabaseInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="io.github.jan.supabase.auth.SupabaseInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="com.russhwolf.settings.SettingsInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <activity
            android:name="com.razorpay.MagicXActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />
        <activity
            android:name="com.google.android.gms.auth.api.signin.internal.SignInHubActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />
        <!--
            Service handling Google Sign-In user revocation. For apps that do not integrate with
            Google Sign-In, this service will never be started.
        -->
        <service
            android:name="com.google.android.gms.auth.api.signin.RevocationBoundService"
            android:exported="true"
            android:permission="com.google.android.gms.auth.api.signin.permission.REVOCATION_NOTIFICATION"
            android:visibleToInstantApps="true" /> <!-- Needs to be explicitly declared on P+ -->
        <uses-library
            android:name="org.apache.http.legacy"
            android:required="false" />

        <activity
            android:name="com.google.android.gms.common.api.GoogleApiActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>

        <activity
            android:name="com.razorpay.DeeplinkActivity"
            android:exported="true"
            android:theme="@style/CheckoutTheme" >
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="com.example.feesmanager"
                    android:scheme="razorpay" />
            </intent-filter>
        </activity> <!-- The activities will be merged into the manifest of the hosting app. -->
        <activity
            android:name="com.google.android.play.core.common.PlayCoreDialogWrapperActivity"
            android:exported="false"
            android:stateNotNeeded="true"
            android:theme="@style/Theme.PlayCore.Transparent" />
    </application>

</manifest>
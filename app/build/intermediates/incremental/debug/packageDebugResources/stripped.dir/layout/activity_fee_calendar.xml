<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E" android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <LinearLayout android:orientation="horizontal" android:background="@drawable/bg_header_dark"
        android:padding="16dp" android:gravity="center_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:id="@+id/tvCalendarTitle" android:text="📅 Fee Calendar"
            android:textSize="20sp" android:textStyle="bold" android:textColor="#F1F5F9"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:orientation="vertical" android:padding="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- Summary card -->
            <LinearLayout android:background="@drawable/bg_card_modern" android:orientation="horizontal"
                android:padding="16dp" android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <LinearLayout android:orientation="vertical" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="Total Paid" android:textColor="#94A3B8" android:textSize="12sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvCalTotalPaid" android:text="₹0"
                        android:textColor="#22C55E" android:textSize="20sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="Total Pending" android:textColor="#94A3B8" android:textSize="12sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/tvCalTotalPending" android:text="₹0"
                        android:textColor="#EF4444" android:textSize="20sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:id="@+id/calendarList" android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>

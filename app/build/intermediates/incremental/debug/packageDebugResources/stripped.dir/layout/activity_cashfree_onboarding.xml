<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <LinearLayout
            android:orientation="horizontal"
            android:background="@drawable/bg_header_dark"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingTop="14dp"  android:paddingBottom="14dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <TextView
                android:id="@+id/cfBtnBack"
                android:text="←"
                android:textSize="22sp" android:textColor="#F1F5F9"
                android:paddingEnd="14dp"
                android:clickable="true" android:focusable="true"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_weight="1"
                android:layout_width="0dp" android:layout_height="wrap_content">
                <TextView
                    android:text="💳 Payment Setup"
                    android:textSize="18sp" android:textStyle="bold" android:textColor="#F1F5F9"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView
                    android:text="Powered by Cashfree Easy Split"
                    android:textSize="11sp" android:textColor="#6366F1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Progress Bar ──────────────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/cfProgressBar"
            android:visibility="gone"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <!-- ══ CONNECTED STATE ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cfLayoutConnected"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="20dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- Status Card -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_card_modern"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">

                <TextView
                    android:text="✅"
                    android:textSize="40sp" android:gravity="center"
                    android:layout_marginBottom="8dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>

                <TextView
                    android:text="Payment Setup Active"
                    android:textSize="20sp" android:textStyle="bold"
                    android:textColor="#22C55E" android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>

                <!-- Vendor ID row -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView
                        android:text="🔑 "
                        android:textSize="14sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/cfTvVendorId"
                        android:text="Vendor ID: —"
                        android:textSize="13sp" android:textColor="#94A3B8"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Vendor Status row -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView
                        android:text="🏦 "
                        android:textSize="14sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/cfTvVendorStatus"
                        android:text="Vendor: —"
                        android:textSize="13sp" android:textColor="#FFB800"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- KYC Status row -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView
                        android:text="📋 "
                        android:textSize="14sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/cfTvKycStatus"
                        android:text="KYC: —"
                        android:textSize="13sp" android:textColor="#FFB800"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Settlement Status row -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView
                        android:text="💰 "
                        android:textSize="14sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/cfTvSettlementStatus"
                        android:text="Settlement: Pending"
                        android:textSize="13sp" android:textColor="#94A3B8"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Info note -->
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/bg_card_modern"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView
                    android:text="ℹ️ "
                    android:textSize="16sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView
                    android:text="KYC approval may take 1–2 business days. Students can pay once Vendor Status shows ✅ Active."
                    android:textSize="12sp" android:textColor="#94A3B8"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"/>
            </LinearLayout>

            <Button
                android:id="@+id/cfBtnDisconnect"
                android:text="Update Bank Details"
                android:textAllCaps="false" android:textColor="#EF4444" android:textSize="14sp"
                android:background="@drawable/bg_card_modern"
                android:stateListAnimator="@null"
                android:layout_width="match_parent" android:layout_height="48dp"/>

        </LinearLayout>

        <!-- ══ NOT CONNECTED STATE ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/cfLayoutNotConnected"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- Explainer card -->
            <LinearLayout
                android:orientation="vertical"
                android:background="@drawable/bg_card_modern"
                android:padding="20dp"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView
                    android:text="💡 Receive Student Payments Directly"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="#F1F5F9"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView
                    android:text="✅  Students pay via UPI, Cards, Net Banking\n✅  100% goes directly to your bank account\n✅  Automated receipt and status updates\n✅  Secured by Cashfree Payment Gateway"
                    android:textSize="13sp" android:textColor="#94A3B8"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>

            <TextView
                android:text="YOUR BANK DETAILS"
                android:textSize="11sp" android:textColor="#6366F1"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <!-- Account Holder Name -->
            <TextView
                android:text="Account Holder Name *"
                android:textSize="13sp" android:textColor="#94A3B8"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/cfEtAccountName"
                android:hint="Name as per bank account"
                android:textColor="#F1F5F9" android:textColorHint="#4B5563"
                android:background="@drawable/bg_input_modern"
                android:padding="14dp" android:textSize="14sp"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <!-- Account Number -->
            <TextView
                android:text="Bank Account Number *"
                android:textSize="13sp" android:textColor="#94A3B8"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/cfEtAccountNumber"
                android:hint="Your bank account number"
                android:textColor="#F1F5F9" android:textColorHint="#4B5563"
                android:background="@drawable/bg_input_modern"
                android:padding="14dp" android:textSize="14sp"
                android:inputType="number"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <!-- IFSC Code -->
            <TextView
                android:text="IFSC Code *"
                android:textSize="13sp" android:textColor="#94A3B8"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/cfEtIfscCode"
                android:hint="e.g. SBIN0001234"
                android:textColor="#F1F5F9" android:textColorHint="#4B5563"
                android:background="@drawable/bg_input_modern"
                android:padding="14dp" android:textSize="14sp"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <TextView
                android:text="KYC DETAILS"
                android:textSize="11sp" android:textColor="#6366F1"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <!-- PAN Number -->
            <TextView
                android:text="PAN Number * (Required for KYC)"
                android:textSize="13sp" android:textColor="#94A3B8"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/cfEtPanNumber"
                android:hint="e.g. ABCDE1234F"
                android:textColor="#F1F5F9" android:textColorHint="#4B5563"
                android:background="@drawable/bg_input_modern"
                android:padding="14dp" android:textSize="14sp"
                android:inputType="textCapCharacters"
                android:maxLength="10"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <!-- Phone Number -->
            <TextView
                android:text="Mobile Number * (Linked to bank)"
                android:textSize="13sp" android:textColor="#94A3B8"
                android:layout_marginBottom="4dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/cfEtPhone"
                android:hint="10-digit mobile number"
                android:textColor="#F1F5F9" android:textColorHint="#4B5563"
                android:background="@drawable/bg_input_modern"
                android:padding="14dp" android:textSize="14sp"
                android:inputType="phone"
                android:maxLength="10"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

            <!-- Security note -->
            <LinearLayout
                android:orientation="horizontal"
                android:background="@drawable/bg_card_modern"
                android:padding="12dp"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView
                    android:text="🔒 "
                    android:textSize="16sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView
                    android:text="Your details are securely processed by Cashfree. PAN is used only for KYC verification."
                    android:textSize="12sp" android:textColor="#94A3B8"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_weight="1"
                    android:layout_width="0dp" android:layout_height="wrap_content"/>
            </LinearLayout>

            <Button
                android:id="@+id/cfBtnSetup"
                android:text="🔗 Submit &amp; Activate Payments"
                android:textAllCaps="false" android:textColor="#fff"
                android:textSize="16sp" android:textStyle="bold"
                android:backgroundTint="#22C55E"
                android:stateListAnimator="@null"
                android:layout_width="match_parent" android:layout_height="56dp"/>

            <TextView
                android:text="Business type will be set to 'Education' automatically."
                android:textSize="11sp" android:textColor="#475569"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>

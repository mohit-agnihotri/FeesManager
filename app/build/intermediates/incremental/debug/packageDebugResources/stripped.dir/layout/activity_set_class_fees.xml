                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:orientation="horizontal" android:layout_marginBottom="10dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                <LinearLayout android:background="@drawable/bg_card" android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical" android:layout_weight="1" android:layout_marginEnd="6dp" android:layout_width="0dp" android:layout_height="54dp">
                    <TextView android:text="Class 3" android:textColor="#94A3B8" android:textSize="13sp" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>

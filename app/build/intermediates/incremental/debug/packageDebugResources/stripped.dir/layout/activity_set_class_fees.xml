                <LinearLayout android:background="@drawable/bg_card" android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="54dp">
                    <TextView android:text="Class 12" android:textColor="#94A3B8" android:textSize="13sp" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/c12" android:hint="₹" android:textColor="#F1F5F9" android:textColorHint="#475569" android:background="@null" android:inputType="number" android:textSize="15sp" android:gravity="end" android:layout_width="80dp" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <LinearLayout android:padding="16dp" android:background="#0A0F1E"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <Button android:id="@+id/btnSaveFees" android:text="💾 Save Fees"
            android:textAllCaps="false" android:textColor="#fff" android:textSize="16sp"
            android:backgroundTint="#6366F1" android:stateListAnimator="@null"
            android:layout_width="match_parent" android:layout_height="56dp"/>
    </LinearLayout>

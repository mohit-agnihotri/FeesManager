                    <EditText android:id="@+id/c11" android:hint="₹" android:textColor="#F1F5F9" android:textColorHint="#475569" android:background="@null" android:inputType="number" android:textSize="15sp" android:gravity="end" android:layout_width="80dp" android:layout_height="wrap_content"/>

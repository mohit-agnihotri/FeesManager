<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E" android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="horizontal" android:background="@drawable/bg_header_dark"
        android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:text="⚙️ Set Class Fees" android:textSize="20sp"
            android:textStyle="bold" android:textColor="#F1F5F9"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
    <ScrollView android:layout_weight="1" android:layout_width="match_parent" android:layout_height="0dp">

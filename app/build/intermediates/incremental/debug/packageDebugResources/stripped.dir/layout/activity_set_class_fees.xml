                    <TextView android:text="Class 1" android:textColor="#94A3B8" android:textSize="13sp" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/c1" android:hint="₹" android:textColor="#F1F5F9" android:textColorHint="#475569" android:background="@null" android:inputType="number" android:textSize="15sp" android:gravity="end" android:layout_width="80dp" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:background="@drawable/bg_card" android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_width="0dp" android:layout_height="54dp">
                    <TextView android:text="Class 2" android:textColor="#94A3B8" android:textSize="13sp" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content"/>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <LinearLayout android:orientation="vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <!-- Header -->
        <LinearLayout android:orientation="horizontal"
            android:background="@drawable/bg_header_dark"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingTop="14dp" android:paddingBottom="14dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:id="@+id/btnBack" android:text="←"
                android:textSize="22sp" android:textColor="#F1F5F9"
                android:paddingEnd="14dp" android:clickable="true" android:focusable="true"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <LinearLayout android:orientation="vertical" android:layout_weight="1"
                android:layout_width="0dp" android:layout_height="wrap_content">
                <TextView android:text="💳 Enable Online Payments"
                    android:textSize="18sp" android:textStyle="bold" android:textColor="#F1F5F9"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Powered by Razorpay Route"
                    android:textSize="11sp" android:textColor="#6366F1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <ProgressBar android:id="@+id/progressOnboarding"
            android:visibility="gone"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <!-- ══ CONNECTED STATE ═══════════════════════════════════════════════ -->
        <LinearLayout android:id="@+id/layoutConnected"
            android:orientation="vertical" android:visibility="gone"
            android:padding="20dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- Success card -->
            <LinearLayout android:orientation="vertical"
                android:background="@drawable/bg_card_modern"
                android:padding="20dp" android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="✅" android:textSize="40sp" android:gravity="center"
                    android:layout_marginBottom="8dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvConnectionStatus"
                    android:text="Payments Active" android:textSize="20sp"
                    android:textStyle="bold" android:textColor="#22C55E" android:gravity="center"
                    android:layout_marginBottom="6dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvConnectedAccountId"
                    android:text="Account: acc_••••••••••••" android:textSize="13sp"
                    android:textColor="#94A3B8" android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="Students can now pay fees online.\nPayments go directly to your bank account."
                    android:textSize="13sp" android:textColor="#64748B" android:gravity="center"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>

            <Button android:id="@+id/btnDisconnect"
                android:text="Disconnect / Update Bank Details"
                android:textAllCaps="false" android:textColor="#EF4444" android:textSize="14sp"
                android:background="@drawable/bg_card_modern" android:stateListAnimator="@null"
                android:layout_width="match_parent" android:layout_height="48dp"/>
        </LinearLayout>

        <!-- ══ NOT CONNECTED STATE ═══════════════════════════════════════════ -->
        <LinearLayout android:id="@+id/layoutNotConnected"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- Explainer -->
            <LinearLayout android:orientation="vertical"
                android:background="@drawable/bg_card_modern"
                android:padding="20dp" android:layout_marginBottom="20dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="💡 Receive Payments Securely" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="#F1F5F9"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="✅  Students pay via UPI, Cards, Netbanking\n✅  Money routes directly to your bank account\n✅  Automated receipts and status updates\n✅  No platform fee! You get 100%"
                    android:textSize="13sp" android:textColor="#94A3B8"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>

            <TextView android:text="YOUR BANK DETAILS"
                android:textSize="11sp" android:textColor="#6366F1"
                android:letterSpacing="0.12" android:layout_marginBottom="10dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>

            <LinearLayout android:id="@+id/layoutKeyEntry"
                android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                
                <TextView android:text="Account Holder Name"
                    android:textSize="13sp" android:textColor="#94A3B8"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etAccountName"
                    android:hint="Name as per bank account"
                    android:textColor="#F1F5F9" android:textColorHint="#4B5563"
                    android:background="@drawable/bg_input_modern"
                    android:padding="14dp" android:textSize="14sp"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="16dp"
                    android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

                <TextView android:text="Account Number"
                    android:textSize="13sp" android:textColor="#94A3B8"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etAccountNumber"
                    android:hint="Your bank account number"
                    android:textColor="#F1F5F9" android:textColorHint="#4B5563"
                    android:background="@drawable/bg_input_modern"
                    android:padding="14dp" android:textSize="14sp"
                    android:inputType="number"
                    android:layout_marginBottom="16dp"
                    android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

                <TextView android:text="IFSC Code"
                    android:textSize="13sp" android:textColor="#94A3B8"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <EditText android:id="@+id/etIfscCode"
                    android:hint="e.g. SBIN0001234"
                    android:textColor="#F1F5F9" android:textColorHint="#4B5563"
                    android:background="@drawable/bg_input_modern"
                    android:padding="14dp" android:textSize="14sp"
                    android:inputType="textCapCharacters"
                    android:layout_marginBottom="24dp"
                    android:layout_width="match_parent" android:layout_height="@dimen/btn_height"/>

                <!-- Security note -->
                <LinearLayout android:orientation="horizontal"
                    android:background="@drawable/bg_card_modern"
                    android:padding="12dp" android:layout_marginBottom="14dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="🔒 " android:textSize="16sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Your details are securely saved directly in Razorpay for receiving payments."
                        android:textSize="12sp" android:textColor="#94A3B8"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_weight="1"
                        android:layout_width="0dp" android:layout_height="wrap_content"/>
                </LinearLayout>

                <Button android:id="@+id/btnConnectRazorpay"
                    android:text="🔗 Securely Connect Account"
                    android:textAllCaps="false" android:textColor="#fff"
                    android:textSize="16sp" android:textStyle="bold"
                    android:backgroundTint="#22C55E" android:stateListAnimator="@null"
                    android:layout_width="match_parent" android:layout_height="56dp"/>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <LinearLayout android:orientation="vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <!-- Header -->
        <LinearLayout android:orientation="horizontal" android:background="@drawable/bg_header_dark"
            android:padding="16dp" android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="✏️ Edit Student" android:textSize="20sp"
                android:textStyle="bold" android:textColor="#F1F5F9"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:padding="20dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">

            <!-- Student Name -->
            <TextView android:text="Student Name" android:textColor="#94A3B8"
                android:textSize="13sp" android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etName" android:hint="Full name"
                android:textColor="#F1F5F9" android:textColorHint="#475569"
                android:background="@drawable/bg_input_modern" android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="54dp"/>

            <!-- Class -->
            <TextView android:text="Class" android:textColor="#94A3B8"
                android:textSize="13sp" android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etClass" android:hint="e.g. 10, 11, 12"
                android:textColor="#F1F5F9" android:textColorHint="#475569"
                android:background="@drawable/bg_input_modern" android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="54dp"/>

            <!-- WhatsApp -->
            <TextView android:text="WhatsApp Number" android:textColor="#94A3B8"
                android:textSize="13sp" android:layout_marginBottom="6dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etWhatsapp" android:hint="10-digit number"
                android:textColor="#F1F5F9" android:textColorHint="#475569"
                android:background="@drawable/bg_input_modern" android:padding="14dp"
                android:inputType="phone" android:layout_marginBottom="24dp"
                android:layout_width="match_parent" android:layout_height="54dp"/>

            <!-- ── Fees Section ─────────────────────────────── -->
            <LinearLayout android:orientation="vertical"
                android:background="@drawable/bg_card_modern" android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">

                <TextView android:text="💰 Update This Month's Fees"
                    android:textColor="#A5B4FC" android:textSize="14sp" android:textStyle="bold"
                    android:layout_marginBottom="4dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:id="@+id/tvCurrentFees"
                    android:text="Current: loading…" android:textColor="#94A3B8"
                    android:textSize="12sp" android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <EditText android:id="@+id/etCustomFees"
                    android:hint="Leave blank to keep current amount"
                    android:textColor="#F1F5F9" android:textColorHint="#475569"
                    android:background="@drawable/bg_input_modern" android:padding="14dp"
                    android:inputType="number" android:textSize="16sp"
                    android:layout_width="match_parent" android:layout_height="54dp"/>

                <TextView android:text="⚠️ This updates only this month's fees"
                    android:textColor="#EAB308" android:textSize="11sp"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <Button android:id="@+id/btnUpdate" android:text="💾 Save Changes"
                android:textAllCaps="false" android:textColor="#fff" android:textSize="16sp"
                android:backgroundTint="#6366F1" android:stateListAnimator="@null"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent" android:layout_height="56dp"/>

            <Button android:id="@+id/btnDelete" android:text="🗑️ Delete Student"
                android:textAllCaps="false" android:textColor="#EF4444" android:textSize="15sp"
                android:background="@drawable/bg_card_modern" android:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:layout_width="match_parent" android:layout_height="50dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0F1E"
    android:padding="32dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="⏳"
        android:textSize="72sp"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvApprovalStatus"
        android:text="Waiting for Approval"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#F1F5F9"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tvApprovalMessage"
        android:text="Your join request has been sent.\nPlease wait while the teacher reviews your request."
        android:textSize="15sp"
        android:textColor="#94A3B8"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="40dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Animated dots indicator -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <View android:background="@drawable/bg_pill" android:backgroundTint="#6366F1"
            android:layout_width="10dp" android:layout_height="10dp"
            android:layout_marginEnd="8dp"/>
        <View android:background="@drawable/bg_pill" android:backgroundTint="#6366F1"
            android:layout_width="10dp" android:layout_height="10dp"
            android:layout_marginEnd="8dp"/>
        <View android:background="@drawable/bg_pill" android:backgroundTint="#94A3B8"
            android:layout_width="10dp" android:layout_height="10dp"/>
    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:background="@drawable/bg_card_modern"
        android:padding="20dp"
        android:layout_marginBottom="32dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="What happens next?"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#A5B4FC"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="1. Your teacher will review your request\n2. You\'ll be notified when approved\n3. Once approved, you get full dashboard access"
            android:textSize="13sp"
            android:textColor="#94A3B8"
            android:lineSpacingMultiplier="1.6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnCancelJoin"
        android:text="← Back to Login"
        android:textSize="14sp"
        android:textColor="#94A3B8"
        android:background="@drawable/bg_btn_secondary"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#0A0F1E" android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <!-- Header -->
    <LinearLayout android:orientation="horizontal"
        android:background="@drawable/bg_header_dark"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="36dp" android:paddingBottom="14dp"
        android:gravity="center_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <LinearLayout android:id="@+id/btnBack" android:orientation="vertical"
            android:gravity="center" android:background="@drawable/ripple_card"
            android:padding="10dp" android:layout_marginEnd="8dp"
            android:clickable="true" android:focusable="true"
            android:layout_width="40dp" android:layout_height="40dp">
            <TextView android:text="←" android:textSize="20sp" android:textColor="#F1F5F9"
                android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView android:text="🤖" android:textSize="28sp"
            android:layout_marginEnd="10dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <LinearLayout android:orientation="vertical" android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="wrap_content">
            <TextView android:text="AI Assistant" android:textSize="18sp"
                android:textStyle="bold" android:textColor="#F1F5F9"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvSubtitle"
                android:text="Academy Intelligence"
                android:textSize="12sp" android:textColor="#818CF8"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Refresh data -->
        <LinearLayout android:id="@+id/btnRefresh" android:orientation="vertical"
            android:gravity="center" android:background="@drawable/ripple_card"
            android:padding="8dp" android:clickable="true" android:focusable="true"
            android:layout_marginEnd="4dp"
            android:layout_width="40dp" android:layout_height="40dp">
            <TextView android:text="🔄" android:textSize="18sp" android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- New chat -->
        <LinearLayout android:id="@+id/btnNewChat" android:orientation="vertical"
            android:gravity="center" android:background="@drawable/ripple_card"
            android:padding="8dp" android:clickable="true" android:focusable="true"
            android:layout_width="40dp" android:layout_height="40dp">
            <TextView android:text="🗑" android:textSize="18sp" android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Quick Actions (horizontal scroll) -->
    <HorizontalScrollView
        android:id="@+id/quickActionsScroll"
        android:scrollbars="none"
        android:paddingTop="8dp" android:paddingBottom="8dp"
        android:background="#0D1117"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:id="@+id/layoutQuickActions"
            android:orientation="horizontal"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </HorizontalScrollView>

    <!-- Urgent Issues Banner -->
    <LinearLayout android:id="@+id/layoutUrgentBanner"
        android:orientation="vertical"
        android:background="@drawable/bg_priority_urgent"
        android:padding="12dp" android:layout_margin="10dp"
        android:visibility="gone"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextView android:id="@+id/tvUrgentTitle"
            android:text="⚠️ Urgent Issues Detected"
            android:textSize="14sp" android:textStyle="bold" android:textColor="#FCA5A5"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvUrgentDetails"
            android:text="" android:textSize="12sp" android:textColor="#94A3B8"
            android:layout_marginTop="4dp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="12dp"
        android:scrollbars="none"
        android:layout_width="match_parent" android:layout_height="0dp"/>

    <!-- Input area -->
    <LinearLayout android:orientation="horizontal"
        android:background="#111827"
        android:padding="10dp" android:gravity="center_vertical"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <EditText android:id="@+id/etMessage"
            android:hint="Ask about your academy data..."
            android:background="@drawable/bg_input_modern"
            android:textColor="#F1F5F9" android:textColorHint="#64748B"
            android:textSize="14sp" android:padding="12dp"
            android:maxLines="4" android:inputType="textMultiLine"
            android:layout_weight="1"
            android:layout_width="0dp" android:layout_height="wrap_content"/>

        <LinearLayout android:id="@+id/btnSend" android:orientation="vertical"
            android:gravity="center" android:background="@drawable/bg_ai_fab"
            android:padding="10dp" android:clickable="true" android:focusable="true"
            android:layout_marginStart="6dp"
            android:layout_width="44dp" android:layout_height="44dp">
            <TextView android:text="➤" android:textSize="18sp" android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
